---
// @ts-nocheck
import HeaderButton from './HeaderButton.astro';
import Logo from './Logo.astro';

export interface Props {
  businessName?: string;
  ctaButton?: {text: string; url: string; style: string};
}

const {
  businessName = 'Richard Waine Photography',
  ctaButton = { text: 'GET PRICING', url: '/rates', style: 'luxury' }
} = Astro.props;
---

<!-- Sophisticated Header -->
<header class="luxury-header" id="luxuryHeader">
    <div class="header-content">
        <div class="logo-container">
            <a href="/" aria-label="Richard Waine Photography Home">
            <Logo class="logo" />



            </a>
        </div>
        <div class="header-cta-wrapper button-wrapper">
        <HeaderButton text={ctaButton.text} url={ctaButton.url} />
        </div>
    </div>
</header>

<style>

    /* Sophisticated Header */
    .luxury-header {
        position: fixed;
        inset:0;
        width: 100%;
        height: var(--header-height);
        z-index: 1000;
        background: var(--drkbg);
        color: var(--ltclr);
        box-shadow: 0px 1px 75px rgb(3, 169, 244, .25);
        

    }


    .header-content {
        max-width: 100%;
        width: 100%;
        margin: 0 auto;
        height: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        
    }

    .logo {

        width: 100%;
        height:var(--header-height);
        filter: drop-shadow(0 0 30px rgba(3, 169, 244, 0.15));
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        color: white;
    }

    .logo-container {
      margin: 0 auto;
    }

    .header-cta-wrapper {
      display: none;
    }

    /* ==========================================
   TABLET - min-width: 48em (768px)
   ========================================== */
    @media (min-width: 48em) {
      .header-content {
        max-width: 80%;
      }

      .logo {
        width: auto;
      }

      .logo-container {
        margin: 0;
      }

      .header-cta-wrapper {
        display: block;
      }
    }
</style>
