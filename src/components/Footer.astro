---
// @ts-nocheck
import FacebookIcon from './icons/FacebookIcon.astro';
import InstagramIcon from './icons/InstagramIcon.astro';
import PinterestIcon from './icons/PinterestIcon.astro';
import LinkedInIcon from './icons/LinkedInIcon.astro';
import GoogleIcon from './icons/GoogleIcon.astro';
import Logo from './Logo.astro';import { buildOrganizationSchema } from '../utils/schema';

export interface Props {
  businessInfo?: {name: string; address: string; phone: string};
  socialLinks?: Array<{platform: string; url: string; ariaLabel: string}>;
  areasServiced?: Array<{name: string; url: string}>;
  services?: Array<{name: string; url: string}>;
  quickLinks?: Array<{name: string; url: string}>;
  copyrightYear?: number;
}

const {
  businessInfo = {
    name: 'Richard Waine Photography',
    address: '20 North Queen Street, Lancaster, PA 17603',
    phone: '(717) 925-0061'
  },
  socialLinks = [
    { platform: 'facebook', url: 'https://www.facebook.com/RichardWainePhotography', ariaLabel: 'link to Facebook profile' },
    { platform: 'instagram', url: 'https://www.instagram.com/richardwaine', ariaLabel: 'link to Instagram profile' },
    { platform: 'pinterest', url: 'https://www.pinterest.com/RichardWaine', ariaLabel: 'link to Pinterest profile' },
    { platform: 'linkedin', url: 'https://www.linkedin.com/in/richardwaine', ariaLabel: 'link to LinkedIn profile' },
    { platform: 'google', url: 'https://share.google/CkLljxW0txK4OyLKt', ariaLabel: 'link to Google Business Profile' }
  ],
  areasServiced = [
    { name: 'Lancaster', url: '/' },
    { name: 'Harrisburg', url: '/harrisburg-headshots' },
    { name: 'York', url: '/york-headshots' },
    { name: 'Philadelphia', url: '/philadelphia-headshots' },
    { name: 'Baltimore', url: '/baltimore-headshots' },
    { name: 'Delaware', url: '/delaware-headshots' }
  ],

  services =[
    { name: 'Business Headshots', url:'/business-headshots'},
    { name: 'Acting Headshots', url:'/acting-headshots'},
    { name: 'LinkedIn Headshots', url:'/linkedin-headshots'},
    { name: 'Office Headshots', url:'/office-headshots'},
    { name: 'Gift Cards', url:'/gift-certificates'},
  ],

  company =[
    { name: 'About', url: '/about-lancaster-headshot-photographer-richard-waine' },
    { name: 'Team', url: '/my-team' },
    { name: 'Studio', url: '/richard-waine-photography-studio' },
    { name: 'Contact', url: '/contact-lancaster-headshot-photographer-richard-waine' },
    
  ],

  quickLinks = [
    { name: 'Blog', url: '/blog' },
    { name: 'Resources', url: '/resources' },
    { name: 'Reviews', url: '/reviews' },
    { name: 'Terms', url: '/terms-and-conditions' },
    { name: 'Privacy Policy', url: '/privacy-policy' },
  ],
  copyrightYear = new Date().getFullYear()
} = Astro.props;

// Icon component mapping
const iconComponents = {
  facebook: FacebookIcon,
  instagram: InstagramIcon,
  pinterest: PinterestIcon,
  linkedin: LinkedInIcon,
  google: GoogleIcon
};

// Generate Organization schema
const socialUrls = socialLinks.map(link => link.url);
const organizationSchema = buildOrganizationSchema(
  businessInfo.name,
  "https://richardwainephotography.com",
  "Professional headshot photographer in Lancaster, PA specializing in business headshots, acting headshots, LinkedIn profiles, and corporate photography",
  "Lancaster",
  "PA",
  "+1-717-925-0061",
  socialUrls,
  "Richard Waine",
  "Professional Headshot Photographer"
);
---

<!-- Footer Access Trapezoid -->
<div class="footer-trigger" id="footerTrigger" tabindex="0" role="button" aria-label="Open footer menu" aria-expanded="false">
    <div class="trapezoid-indicator">
        <span class="trapezoid-text">MENU</span>
    </div>
</div>

<div class="footer-panel" id="footerPanel">
    <div class="view-slider">
        <section class="view" id="view-nav">
    <div class="footer-content">
        <div class="footer-main-row">
             <div class="logo-container">
            <a href="/" aria-label="Richard Waine Photography Home">
            <Logo class="logo" />            </a>
            <button id="btn-open-news" class="newsletter-cta">Join The Inner Circle</button>
        </div>
            
            
            <div class="footer-section">
                <div class="footer-section-title">AREAS SERVICED</div>
                <ul class="footer-links">
                    {areasServiced.map(area => (
                        <li><a href={area.url}>{area.name}</a></li>
                    ))}
                </ul>
            </div>

            <div class="footer-section">
                <div class="footer-section-title">SERVICES</div>
                <ul class="footer-links">
                    {services.map(service => (
                        <li><a href={service.url}>{service.name}</a></li>
                    ))}
                </ul>
            </div>


            <div class="footer-section">
                <div class="footer-section-title">COMPANY</div>
                <ul class="footer-links">
                    {company.map(link => (
                        <li><a href={link.url}>{link.name}</a></li>
                    ))}
                </ul>
            </div>

            
            <div class="footer-section">
                <div class="footer-section-title">RESOURCES</div>
                <ul class="footer-links">
                    {quickLinks.map(link => (
                        <li><a href={link.url}>{link.name}</a></li>
                    ))}
                </ul>
            </div>
        </div>
        
        <hr class="footer-divider">
        
        <div class="footer-bottom-row">
            <div class="footer-contact">
                <a class="telephone" href={`tel:${businessInfo.phone.replace(/\\D/g, '')}`}>{businessInfo.phone}</a>
                <p>{businessInfo.address}</p>
                <p class="copyright-text">Copyright &copy; <a href="/">{businessInfo.name}</a> {copyrightYear} | All Rights Reserved</p>
            </div>
            
            <div class="footer-social">
                <ul class="social-icons">
                    {socialLinks.map(social => {
                        const IconComponent = iconComponents[social.platform];
                        return (
                            <li>
                                <a href={social.url} aria-label={social.ariaLabel}>
                                    <IconComponent />
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>
        </div>
    </div>
        </section>

        <section class="view newsletter-view" id="view-news">
            <div class="newsletter-container">
                <button class="btn-back" id="btn-close-news">← Back to Menu</button>
                <div class="newsletter-title">The Inner Circle</div>
                <p>Be the first to know about studio updates, new headshot dates, and professional tips.</p>

                <div class="ml-embedded" data-form="ckP0SH"></div>
            </div>
        </section>
    </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

<style>

    /* Footer Access Trapezoid */
    .footer-trigger {
        --_footer-trigger-width: 225px;
        --_footer-trigger-height: calc(var(--_footer-trigger-width) / 4.5);

        position: fixed;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: var(--_footer-trigger-width);
        height: var(--_footer-trigger-height);
        z-index: 1000;
        cursor: pointer;
        background: transparent;
        filter: drop-shadow(0 0 6px var(--glow-clr-strong));
    }

    .trapezoid-indicator {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: var(--_footer-trigger-height);
        background: linear-gradient(135deg,
            rgba(0, 0, 0, 1) 0%,
            rgba(26, 26, 26, 1) 100%);
        backdrop-filter: blur(15px);
        border-top: 1px solid var(--glow-clr-medium);
        clip-path: polygon(20% 0%, 80% 0%, 100% 100%, 0% 100%);
        opacity: 1;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px var(--shadow-clr-medium);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Firefox-specific fix: backdrop-filter makes dark gradient invisible */
    @-moz-document url-prefix() {
        .trapezoid-indicator {
            backdrop-filter: none;
        }
    }

    .trapezoid-text {
        color: var(--accent);
        font-family:var(--ff-primary);
        font-weight: var(--fw-semi-bold);
        font-size: var(--fs-325);
        letter-spacing: 1px;
        text-transform: uppercase;
        position: relative;
        z-index: 10;
    }


    .footer-panel {
        position: fixed;
        bottom: -100%;
        left: 0;
        right: 0;
        height: calc(100vh - var(--header-height));
        overflow-y: auto;
        background: linear-gradient(135deg,
            rgba(15, 15, 15, 1) 0%,
            rgba(26, 26, 26, 1) 100%);
        backdrop-filter: blur(20px) saturate(180%);
        border-top: 1px solid rgba(3, 169, 244, 0.2);
        z-index: 999;
        transition: all 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 0px 10px var(--shadow-clr-deep);
    }



    .footer-panel.open {
        bottom: 0;
    }



    .footer-trigger:focus-visible {
        outline: 2px solid orange;
        outline-offset: 2px;
       
    }

    

    /* Mobile-First Replacement */
    .footer-content {
        width: 100%;
        padding: var(--size-650);
        font-family: var(--ff-primary);
        color: var(--ltclr);
        margin-bottom:2em;
    }

    .footer-main-row {
        display: grid;
        grid-template-columns: 1fr;
        align-items: start;
        gap: var(--size-650);
        margin-bottom: var(--size-4);
        place-items: center;
        text-align: center;
    }

    .footer-logo-section {
        display: flex;
        justify-content: center;
        align-self:center;


    }

    .logo-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        display: none;
    }

    .logo {
        width: 150px;
        height: auto;
        color:#fff;
        
    }

    .footer-section .footer-section-title {
        color: var(--accent);
        font-size: var(--fs-350) /*0.9rem */;
        font-weight: var(--fw-semi-bold);
        margin-bottom: calc(var(--size-650) / 2); /* 15px */
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .footer-links {
        padding: 0;
        list-style: none;
        margin: 0;
    }

    .footer-links li {
        margin-bottom: var(--size-1);
    }

    .footer-links a {
        color: var(--faded);
        text-decoration: none;
        font-size: var(--fs-350) /*0.9rem */;
        transition: color 0.3s ease;
    }

    .footer-links a:hover {
        color: var(--ltclr);
    }

    .footer-divider {
        border: none;
        border-top: 1px solid rgba(187, 187, 187, 0.5);
        width: 80%;
        margin: var(--size-650) auto;
    }

    .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr;
        align-items: center;
        gap: var(--size-4);
        place-items: center;
        text-align: center;
    }

    .footer-contact {
        text-align: center;
    }

    .footer-contact .telephone {
        color: var(--faded);
        text-decoration: none;
        font-weight: var(--fw-semi-bold);
        display: block;
        margin-bottom: var(--size-2);
    }

    .footer-contact p {
        color: var(--faded);
        margin: var(--size-1) 0;
        font-size: var(--fs-350) 
    }

    .footer-contact .copyright-text {
        margin-top: calc(var(--size-650) / 2);
    }

    .footer-contact .copyright-text a {
        color: var(--faded);
        text-decoration: none;
    }

    .footer-social {
        display: flex;
        justify-content: center;
    }

    .social-icons {
        padding: 0;
        margin: 0;
        list-style: none;
        display: flex;
        gap: var(--size-3);
    }

    .social-icons a {
        --_icon-width:44px;
        --_icon-height:var(--_icon-width);

        width: var(--_icon-width);
        height: var(--_icon-height);
        line-height: 44px;
        text-align: center;
        color: var(--ltclr);
        font-size: var(--fs-500);
        transition: color 0.3s ease;
    }

    .social-icons a:hover {
        color: var(--accent);
    }

    /* ==========================================
   SLIDER FUNCTIONALITY
   ========================================== */
    .view-slider {
        display: flex;
        width: 200%;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .footer-panel.show-newsletter .view-slider {
        transform: translateX(-50%);
    }

    .view {
        width: 50%;
        height: 100%;
        overflow-y: auto;
        box-sizing: border-box;
    }

    /* Newsletter View Styles */
    .newsletter-view {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: var(--ltclr);
        font-family: var(--ff-primary);
        padding: var(--size-650);
        background: linear-gradient(135deg,
            rgba(15, 15, 15, 1) 0%,
            rgba(26, 26, 26, 1) 100%);
    }

    .newsletter-container {
        width: 100%;

    }

    .newsletter-title {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: var(--size-2);
        color: var(--accent);
        text-transform: uppercase;
        text-shadow: 0 2px 8px var(--shadow-clr-deep);
    }

    .newsletter-container p {
        color: var(--faded);
        margin-inline: auto;
        margin-bottom: var(--size-5);
        max-width: 500px;
    }

    .btn-back {
        background: none;
        border: 1px solid var(--faded);
        color: var(--faded);
        padding: 8px 20px;
        cursor: pointer;
        margin-bottom: var(--size-5);
        text-transform: uppercase;
        font-size: 10px;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        font-family: var(--ff-primary);
    }

    .btn-back:hover {
        border-color: var(--accent);
        color: var(--accent);
    }

    .newsletter-cta {
        background: transparent;
        color: var(--accent);
        border: 1px solid var(--accent);
        padding: 10px 20px;
        font-family: var(--ff-primary);
        font-weight: var(--fw-semi-bold);
        text-transform: uppercase;
        font-size: var(--fs-325);
        cursor: pointer;
        margin-top: 3em;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

    .newsletter-cta:hover {
        background: var(--accent);
        color: #000;
    }

    /* ==========================================
   TABLET - min-width: 48em (768px)
   ========================================== */
    @media (min-width: 48em) {
        .footer-content {
            padding: var(--size-5) var(--size-875);
            
        }

        .footer-main-row {
            grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
            gap: calc(var(--size-650) / 2);
            text-align: left;
            align-items: start;
      
            
        }

        .footer-contact {
            text-align: left;
        }

        .footer-bottom-row {
            grid-template-columns: 1fr 1fr;
            text-align: left;
        }

        .footer-social {
            justify-content: flex-end;
        }

        .footer-panel {
            bottom: -500px;
            height: auto;
            min-height: 500px;
            overflow-y: visible;
        }
        .logo-container{
            display:flex;
            margin-top: -20px;
        }
    }
</style>

<script>
document.addEventListener('astro:page-load', () => {
    const trigger = document.getElementById('footerTrigger');
    const panel = document.getElementById('footerPanel');

    if (trigger && panel) {
        const btnOpenNews = document.getElementById('btn-open-news');
        const btnCloseNews = document.getElementById('btn-close-news');

        trigger.addEventListener('click', () => {
            const isOpen = panel.classList.toggle('open');
            trigger.setAttribute('aria-expanded', isOpen.toString());
            if (!isOpen) {
                setTimeout(() => panel.classList.remove('show-newsletter'), 400);
            }
        });

        // Slide to Newsletter
        if (btnOpenNews) {
            btnOpenNews.addEventListener('click', (e) => {
                e.stopPropagation();
                panel.classList.add('show-newsletter');
            });
        }

        // Slide back to Nav
        if (btnCloseNews) {
            btnCloseNews.addEventListener('click', (e) => {
                e.stopPropagation();
                panel.classList.remove('show-newsletter');
            });
        }

        document.addEventListener('click', (e) => {
            if (!trigger.contains(e.target as Node) && !panel.contains(e.target as Node)) {
                panel.classList.remove('open');
                trigger.setAttribute('aria-expanded', 'false');
            }
        });
    }
});
</script>

<!-- MailerLite Universal Script - Lazy loaded when newsletter view is opened -->
<script is:inline>
    let mailerliteLoaded = false;

    function loadMailerLite() {
        if (mailerliteLoaded) return;
        mailerliteLoaded = true;

        (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
        .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
        n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
        (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
        ml('account', '734406');
    }

    const btnOpenNews = document.getElementById('btn-open-news');
    if (btnOpenNews) {
        btnOpenNews.addEventListener('click', loadMailerLite, { once: true });
    }
</script>
