---
import FloatingStats from '../components/FloatingStats.astro';
import PrimaryButton from './PrimaryButton.astro';
import { buildServiceCatalogSchema } from '../utils/schema';

import { Image } from 'astro:assets';

import adoteImg from '../assets/images/features/Headshot_20240919_William Adote_Richard Waine_Lancaster_PA_0023 (horizontal) - compressed.jpg';
import cottrellImg from '../assets/images/features/Headshot_20220829_Jack Cottrell_Richard_Waine_Lancaster_PA_0318 (horizontal) - compressed.jpg';
import giglioImg from '../assets/images/features/Headshot_20180414_Ken Giglio_Richard_Waine_Lancaster_PA_0060-2 - compressed.jpg';
import chubbImg from '../assets/images/office-headshots/Chubb - ContactSheet (square).jpg';


const {
  srText1 = "about Business Headshots",
  srText2 = "about Acting Headshots",
  srText3 = "about LinkedIn Headshots",
  srText4 = "about Office Headshots",
  primaryButtonText = "Learn More",
  secondaryButtonText = "SCHEDULE CONSULTATION",
  businessHeadshotsUrl = "/business-headshots", // Business Headshots
  actingHeadshotsUrl = "/acting-headshots", // Acting Headshots
  linkedinHeadshotsUrl = "/linkedin-headshots", // LinkedIn Headshots
  officeHeadshotsUrl = "/office-headshots", // Office Headshots
  secondaryButtonUrl = "https://app.acuityscheduling.com/schedule/f0843291/appointment/11959793/calendar/1133425?appointmentTypeIds[]=11959793",
} = Astro.props;

// Define services for schema
const services = [
  {
    name: "Business Headshots",
    description: "Professional business headshots for executives, professionals, and entrepreneurs to elevate your professional image"
  },
  {
    name: "Acting Headshots",
    description: "High-quality acting headshots for performers, actors, and entertainers seeking to showcase their range and personality"
  },
  {
    name: "LinkedIn Headshots",
    description: "Professional LinkedIn profile photos that make you stand out and attract opportunities"
  },
  {
    name: "Office Headshots",
    description: "On-location corporate headshots for teams, ensuring brand consistency across your organization"
  }
];

// Generate Service catalog schema
const servicesSchema = buildServiceCatalogSchema(
  "Richard Waine Photography",
  "Lancaster",
  "PA",
  services
);
---



<section class="features-section features-section-wrapper">
  <div class="features-container">
    <div class="features-scroller">

      <div class="feature-slide">
        <div class="slide-content-wrapper">
          <Image class="slide-image" src={adoteImg} alt="Professional business headshot of man with short dark hair and goatee wearing navy blue suit jacket with light blue patterned tie and white dress shirt photographed against white studio background with clean professional lighting by Richard Waine Photography headshot photographer serving Lancaster, Harrisburg, Philadelphia Pennsylvania, Baltimore Maryland, business headshots, commercial headshots, marketing headshots" width={700} height={560} loading="lazy" />
          <div class="slide-content slide-content1">
            <h2 class="heading">Business Headshots</h2>
            <div class="slide-text">

              <p>
                Corporate Headshots don't have to be boring. They can and should be fun! Contemporary business headshots or business portraits will promote your credibility and earn client trust.
              </p>

              <p>Developing trust is essential. Business headshots ensure that your team images are aligned with brand messaging.

              </p>

              <p>My easy-to-follow system of coaching and direction accentuates and punctuates your perceived level of expertise.

              </p>

              <p>Whether you are looking to motivate and inspire, or project an aura of diplomacy and approachability, a high-quality corporate headshot will set you up for success!

              </p>

            </div>

            <div class="button-wrapper">
              <PrimaryButton text={primaryButtonText} url={businessHeadshotsUrl} srText={srText1} />
            </div>
          </div>

        </div>
      </div>

      <div class="feature-slide">
        <div class="slide-content-wrapper">
         <Image class="slide-image" src={cottrellImg} alt="Professional actor headshot of young man with tousled medium-length brown wavy hair and blue eyes with natural light smile wearing tan suede bomber jacket with snap collar over black v-neck shirt photographed against dark charcoal gray studio backdrop with dramatic professional lighting by Richard Waine Photography actor headshot photographer Lancaster Philadelphia Pennsylvania Newark Wilmington Delaware, acting headshots lancaster, headshots for actors, Lancaster studio headshots" width={600} height={480} loading="lazy" />
          <div class="slide-content slide-content2">
            <h2 class="heading">Acting Headshots</h2>
            <div class="slide-text">


             <p> Casting directors and agents see tons of actor headshots daily. Powerful and professional headshots help you stand out from other performers.</p>

<p>Acting headshots are used to determine if you have the right attributes and personality for a production.</p>

<p>Over my years as a headshot specialist, I have delivered some of the best actor headshots in Lancaster.</p>

<p>I understand the nuances of the performing arts industry and will work with you to create headshots that capture your essence and align with the specific demands of your craft.</p>


            </div>
            <div class="button-wrapper">
              <PrimaryButton text={primaryButtonText} url={actingHeadshotsUrl} srText={srText2} />
            </div>
          </div>

        </div>
      </div>

      <div class="feature-slide">
        <div class="slide-content-wrapper">
          <Image class="slide-image" src={giglioImg} alt="Professional LinkedIn headshot of man with clean-shaven head and trimmed gray goatee and mustache wearing navy blue suit jacket with white open-collar dress shirt photographed against seamless white studio backdrop with soft directional lighting by Richard Waine Photography LinkedIn headshot photographer serving Lancaster York Harrisburg Pennsylvania Baltimore Maryland" width={600} height={480} loading="lazy" />
          <div class="slide-content slide-content3">
            <h2 class="heading">LinkedIn Headshots</h2>
            <div class="slide-text">


             <p>
              LinkedIn is where professionals find value, business relationships, and clients. Using a subpar headshot on your LinkedIn profile is like having no headshot at all.</p>

<p>An incredible LinkedIn headshot demonstrates to your audience that you invest in yourself, that details matter, and that excellence is the guiding principle of how you do business.</p>

<p>Social selling requires a complete and well-rounded social presence. Your audience should receive your business and your team as an authority. Present yourself as the best solution to their problem.

              </p>


            </div>
            <div class="button-wrapper">
              <PrimaryButton text={primaryButtonText} url={linkedinHeadshotsUrl} srText={srText3} />
            </div>
          </div>

        </div>
      </div>

      <div class="feature-slide">
        <div class="slide-content-wrapper">
          <Image class="slide-image" src={chubbImg} alt="Corporate team headshot contact sheet grid displaying 34 diverse Chubb insurance company employees in business professional and business casual attire photographed with consistent gray studio background by Richard Waine Photography on-location corporate headshot photographer, Office Headshots, Professional Headshots on Location, Team Headshots" loading="lazy" width={1080} height={1080} />
          <div class="slide-content slide-content4">
            <h2 class="heading">Office Headshots</h2>
            <div class="slide-text">


             <p>

               Your business is to develop products, serve your clients, improve company performance, and/or care for revenue and expenses.</p>

<p>My business is to care for the marketing needs and the people of your business.</p>

<p>You spend an enormous amount of money on branding, marketing, and communicating company values in order to increase market share and generate revenue.</p>

<p>Presenting your staff as a unified team of professionals goes a long way towards furthering your brand, improving your marketing material, and showing your clients that you care.

              </p>


            </div>
            <div class="button-wrapper">
              <PrimaryButton text={primaryButtonText} url={officeHeadshotsUrl} srText={srText4} />
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />

<script>

import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// Ensure the code runs after all elements are present and styles are calculated
document.addEventListener("astro:page-load", () => {

    // === DIAGNOSTIC START ===
    const featuresStartTime = performance.now();
    console.log(`[DIAGNOSTIC] Features script started at ${featuresStartTime.toFixed(2)}ms`);
    // === DIAGNOSTIC END ===

    let mm = gsap.matchMedia();
    // const DESKTOP_BREAKPOINT = "(min-width: 768px)";
    // const DESKTOP_BREAKPOINT = "(min-width: 48em)";
    const DESKTOP_BREAKPOINT = "(min-width: 67.5em)";
    const REDUCED_MOTION_QUERY = "(prefers-reduced-motion: reduce)";

    // DESKTOP LOGIC (Horizontal Scroll)
    mm.add(DESKTOP_BREAKPOINT, () => {

        const slides = gsap.utils.toArray('.feature-slide');
        const scroller = document.querySelector('.features-scroller');

        // Check for necessary elements
        if (!scroller || slides.length < 2) return;

        // Defer ScrollTrigger refresh to avoid forced reflow during initial page load
        if ('requestIdleCallback' in window) {
            requestIdleCallback(() => ScrollTrigger.refresh());
        } else {
            setTimeout(() => ScrollTrigger.refresh(), 100);
        }

        // Check if user prefers reduced motion
        const prefersReducedMotion = window.matchMedia(REDUCED_MOTION_QUERY).matches;

        // Main horizontal scroll animation controlled by vertical scroll
        const horizontalScroll = gsap.to(slides, {
            xPercent: -100 * (slides.length - 1),
            ease: "none",
            scrollTrigger: {
                trigger: ".features-section",
                pin: true,
                scrub: 1,
                anticipatePin: 1,
                refreshPriority: -1, 
                pinSpacing: true,
                // Calculate end dynamically based on the number of slides
                end: () => `+=${slides.length * window.innerWidth}`,
                invalidateOnRefresh: true,
            }
        });

        // Animate content within each slide (skip decorative animations if reduced motion preferred)
        slides.forEach((slide: any) => {
            const heading = slide.querySelector(".heading");
            const text = slide.querySelector(".slide-text");
            const image = slide.querySelector(".slide-image");

            // Skip decorative animations for reduced motion users, but keep scroll functional
            if (prefersReducedMotion) return;

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: slide,
                    containerAnimation: horizontalScroll,
                    start: "left center",
                    end: "center center",
                    scrub: true,
                }
            });



           if (heading) tl.from(heading, { opacity: 0, ease: "power1.inOut" }, 0);
           if (text) tl.from(text, { opacity: 0, ease: "power2.out" }, 0.2);
           if (image) tl.from(image, { opacity: 0, scale: 0.8, ease: "slow" }, 0);

        });


        return () => {
            ScrollTrigger.getAll().forEach(trigger => trigger.kill());
            gsap.set('.features-section, .features-scroller, .feature-slide, .heading, .slide-text, .slide-image', { clearProps: 'all' });
        };
    });



    // MOBILE FALLBACK LOGIC (Runs ONLY on screens smaller than 768px)
    mm.add("(width < 67.5em)", () => {
        // Clear any pinned/transformed styles left by ScrollTrigger
        gsap.set('.features-section, .features-scroller, .feature-slide', { clearProps: 'all' });
    });

    // === DIAGNOSTIC START ===
    const featuresEndTime = performance.now();
    const featuresDuration = featuresEndTime - featuresStartTime;
    console.log(`[DIAGNOSTIC] Features script finished at ${featuresEndTime.toFixed(2)}ms`);
    console.log(`[DIAGNOSTIC] Features script took ${featuresDuration.toFixed(2)}ms`);
    if (featuresDuration > 50) {
        console.warn(`[DIAGNOSTIC] ⚠️ Features LONG TASK: ${featuresDuration.toFixed(2)}ms`);
    }
    // === DIAGNOSTIC END ===
});

</script>



<style>
.features-section-wrapper{
  padding-block:var(--size-8);
}


/* ==========================================
   MOBILE BASE STYLES
   ========================================== */
.features-section {
  width: 100%;
  overflow: hidden;
  /* Safari GPU acceleration */
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.features-container {
  position: relative;
  width: 100%;
}

.features-scroller {
  display: flex;
  flex-wrap: wrap; 
  width: 100%;
  /* Safari GPU acceleration */
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  will-change: transform;
}

.feature-slide {
  width: 100%; 
  height: auto; 
  flex-shrink: 0;
  display: block;
  padding-block: var(--size-9); 
  background: var(--drkbg);
  color: var(--ltclr);
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.feature-slide:first-child{
  padding-block:0  var(--size-9);
}

.slide-content-wrapper {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  margin-inline: auto;
  place-items: center;
  width: 100%;
  width: calc(100% - var(--size-7));
}



.slide-content{
  margin-top:var(--size-7);
}

p {
  margin-block: var(--size-3);
}

.slide-image {
  display: block;
  margin: auto;
  height: auto;
  box-shadow: var(--shadow);
  width: min(600px, 100%);
}

.slide-content {
  margin-inline: auto;

}

.slide-content h2 {
  text-transform: uppercase;
  font-size: var(--fs-800);
  letter-spacing: 0.05em;
  color: var(--accent);
  font-weight: var(--fw-semi-bold);
  text-align: center;
}

.features-section :global(.primary-btn){
  margin-top:var(--size-5);
  padding: var(--size-3) var(--size-8);
  font-size: var(--fs-350);
}

.button-wrapper{
  justify-self: center;
}

/* ==========================================
   TABLET - min-width: 48em (768px)
   ========================================== */
@media (min-width: 48em) {
.slide-image, .slide-image > img{
padding-inline:0;
}

}



/* ==========================================
   LARGE DESKTOP - min-width: 67.5em (1080px)
   ========================================== */

@media (min-width: 67.5em) {
  
  .slide-content{
    margin-top:var(--size-3);
    max-inline-size:75%;
  }

  .slide-content-wrapper{
    padding-inline:var(--size-7);
     grid-template-columns: 1fr 1.25fr;
    
  }

  .slide-content h2 {
    text-align: start;
  }

  .features-scroller {
    flex-wrap: nowrap; 
    width: fit-content;
  }

  .feature-slide {
    width: 100vw; 
    height: 100vh; 
    display: flex; 
    padding-block: 0;
  }

 .button-wrapper{
    justify-self: left;
  }

}


</style>








