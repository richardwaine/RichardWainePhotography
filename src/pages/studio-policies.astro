    font-weight:var(--fw-semi-bold);
    margin-top:var(--size-7);
    margin-bottom:var(--size-3);
}

p{
    margin-bottom:var(--size-3);
}

ul{
    list-style:none;
    padding-left:var(--size-7);
    margin-block:var(--size-3);

        & > li{
            list-style-type: square;
            margin-bottom:var(--size-2);
        }
}

</style>
