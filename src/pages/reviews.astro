---
import MainLayout from '../layouts/MainLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import { Image } from 'astro:assets';
import { ALL_TESTIMONIALS } from '../data/testimonials';

import { buildReviewSchema } from '../utils/schema';        

// This grabs EVERY image in that folder in one go
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/testimonials/*.{jpeg,jpg,png,gif}');

const h1 = "Reviews";


 // Generate Review schema for each testimonial
  const reviewSchemas = ALL_TESTIMONIALS.map(testimonial =>
    buildReviewSchema(
      {
        author: testimonial.name,
        company: testimonial.company,
        rating: testimonial.rating.toString(),
        reviewBody: testimonial.review,
        datePublished: testimonial.datePublished
      },
      "Richard Waine Photography",
      "https://richardwainephotography.com"
    )
  );
---

<MainLayout title="Richard Waine Photography | Reviews" description="Read testimonials from clients who describe Richard Waine’s headshot sessions as a transformational and enjoyable experience that builds confidence and produces authentic, high-end professional headshots">

  <!-- Individual Review Schemas for each testimonial -->                               
                                                                                         
    {reviewSchemas.map((schema) => (                                                     
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />            
    ))}    

<PageTitle title={h1} titleColor="var(--ltclr)" />

    


<div id="app">
        <div class="blog-container">
            <div class="main-content">
                <section class="filter-section">
                    <div class="filter-header">
                        <h2 class="filter-title">Browse Reviews</h2>
                        <!-- NEW: Filter toggle button for mobile -->
                        <button id="filter-toggle" class="filter-toggle-btn">
                            Filter <span class="arrow">&#9660;</span>
                        </button>
                    </div>
                    <!-- NEW: Wrapper for filter content -->
                    <div class="filter-content" id="filter-content">
                        <div class="filter-tabs" id="category-filters">
                            <button class="filter-btn active" data-category="all">All</button>
                            <button class="filter-btn" data-category="executives">Corporate Executives</button>
                            <button class="filter-btn" data-category="corporate-professionals">Corporate Professionals</button>
                            <button class="filter-btn" data-category="entrepreneurs">Entrepreneurs</button>
                            <button class="filter-btn" data-category="company-employees">Company Employees</button>
                            <button class="filter-btn" data-category="creatives">Creative Professionals</button>
                            <button class="filter-btn" data-category="small-business-owners">Small Business Owners</button>
                            <button class="filter-btn" data-category="legal-professionals">Legal Professionals</button>
                            <button class="filter-btn" data-category="financial-professionals">Financial Professionals</button>
                            <!-- <button class="filter-btn" data-category="dj">DJ's</button> -->
                            <!-- Original HTML had commented out 'venue' button -->
                            <!-- <button class="filter-btn" data-category="venue">Venues</button> -->
                            <!-- <button class="filter-btn" data-category="event-planner">Event Planners</button> -->
                            <!-- <button class="filter-btn" data-category="caterer">Caterers</button> -->
                        </div>

                        <div class="search-container">
                            <input type="text" id="search-input" placeholder="Search Reviews..." class="search-input">
                        </div>
                    </div>
                </section>

                <main class="blog-grid">
                    <div class="category-heading">
                        <h2 id="current-category">All Reviews</h2>
                    </div>
                    <div class="blog-posts" id="blog-posts">
                        <!-- Vendor Cards (your existing content) - UNCHANGED from original -->


                           {[...ALL_TESTIMONIALS].filter((t) => t.review && t.review.trim() !== '').sort((a, b) => (a.displayOrder ?? 0) - (b.displayOrder ?? 0)).map((testimonial) => {
    const fullPath = `/src/assets/images/testimonials/${testimonial.imagePath}`;

    return (
        <article class="blog-card" data-category={testimonial.category}>
            <div class="reviewer-header">
                {images[fullPath] ? (
                    <Image src={images[fullPath]()} alt={testimonial.imageAlt} width={100} height={100} loading="eager" decoding="async" />
                ) : (
                    <div class="avatar-placeholder">Image not found</div>
                )}
                <div class="meta-details">
                    <h3 class="reviewer-name">{testimonial.name}</h3>
                </div>
            </div>
            <div class="quote-wrapper">
                <span class="quote opening-quote">&ldquo;</span>
                <p class="text-content">{testimonial.review}</p>
                <span class="quote closing-quote">&rdquo;</span>
            </div>
        </article>
    );
})}

                    </div>
                
                </main>
            </div>
        </div>
    </div>


<script is:inline>
function initializeResourceFilters() {
  const b = document.querySelectorAll(".blog-card");
  const f = document.getElementById("category-filters");
  const d = document.getElementById("current-category");
  const s = document.getElementById("search-input");
  if (!f || !d || !s) return;
  let a = "all";
  const t = {
    "all": "All Reviews",
    "executives": "Corporate Executives",
    "corporate-professionals": "Corporate Professionals",
    "entrepreneurs": "Entrepreneurs",
    "company-employees": "Company Employees",
    "creatives": "Creative Professionals",
    "small-business-owners": "Small Business Owners",
    "legal-professionals": "Legal Professionals",
    "financial-professionals": "Financial Professionals"
  };

  const filter = () => {
    const term = s.value.toLowerCase();
    b.forEach(card => {
      const cats = card.dataset.category.toLowerCase().split(" ");
      const matchCat = a === "all" || cats.includes(a);
      const title = card.querySelector(".reviewer-name")?.textContent.toLowerCase() || "";
      const excerpt = card.querySelector(".text-content")?.textContent.toLowerCase() || "";
      const matchSearch = !term || title.includes(term) || excerpt.includes(term);
      if (matchCat && matchSearch) {
        card.style.display = "";
      } else {
        card.style.display = "none";
      }
    });
    d.textContent = t[a] || `${a.replace(/-/g, ' ')} Reviews`;
  };

  f.onclick = e => {
    if (e.target.classList.contains("filter-btn")) {
      document.querySelectorAll(".filter-btn").forEach(btn => btn.classList.remove("active"));
      e.target.classList.add("active");
      a = e.target.dataset.category;
      filter();
    }
  };

  s.oninput = filter;

  const toggle = document.getElementById("filter-toggle");
  const content = document.getElementById("filter-content");
  if (toggle && content) {
    toggle.onclick = () => {
      content.classList.toggle("open");
      toggle.classList.toggle("active");
    };
  }

  filter();
}

// Initialize on page load and ViewTransitions
document.addEventListener("DOMContentLoaded", initializeResourceFilters);
document.addEventListener("astro:page-load", initializeResourceFilters);
document.addEventListener("astro:after-swap", initializeResourceFilters);
</script>


</MainLayout>

<style>

:root {
  --pagetitle-h1-margin: 0;
  --border-light-gray: #e5e5e5;
}

        body {
            background: var(--drkbg);
            color: var(--ltclr);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        h1, h2, h3, h4, h5, h6 {
            font-weight: var(--fw-semi-bold);
            margin-block: var(--size-3);
            text-wrap: balance;
        }

        #current-category {
            text-transform: capitalize;
        }

        h2 {
            font-size: var(--fs-500);
        }

        h3 {
            font-size: var(--fs-400);
            font-weight: var(--fw-bold);
            text-transform: uppercase;
        }

        p {
            margin-bottom: var(--size-3);
            text-wrap: pretty;
        }

        a {
            color: var(--accent);
            text-decoration: none;
        }

        button {
            cursor: pointer;
            font-family: inherit;
            outline: none;
        }

        .blog-container {
            width: calc(100% - var(--size-7));
            margin-inline: auto;
        }

        .category-heading {
            margin-bottom: var(--size-3);
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--size-7);
            padding: var(--size-7) 0 0 0;
            justify-content: center;
            margin-bottom: var(--size-9);
        }

        .filter-section {
            position: relative;
            top: auto;
            height: fit-content;
            padding: var(--size-3);
            background: var(--ltclr);
            border: none;
            box-shadow: none;
            border-radius: var(--size-2);
            margin-bottom: var(--size-4);
            color: var(--blkclr);
        }

        .filter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: var(--size-3);
            margin-bottom: var(--size-3);
            border-bottom: 1px solid var(--border-light-gray);
        }

        .filter-toggle-btn {
            display: flex;
            background: var(--blkclr);
            color: var(--ltclr);
            border: none;
            padding: var(--size-2) var(--size-250);
            font-size: var(--fs-350);
            align-items: center;
            gap: var(--size-2);
            transition: background-color var(--transition-fast) ease;
        }

        .filter-toggle-btn:hover {
            background-color: var(--drkbg);
        }

        .filter-toggle-btn .arrow {
            transition: transform var(--transition-slow) ease;
        }

        .filter-toggle-btn.active .arrow {
            transform: rotate(180deg);
        }

        .filter-content {
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
            transition: max-height var(--transition-slow) ease-out, padding var(--transition-slow) ease-out;
        }

        .filter-content.open {
            max-height: 1000px;
        }

        .filter-tabs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--size-2);
            margin: 0 0 var(--size-5) 0;
            font-size: var(--fs-400);
        }

        .search-container {
            margin-top: var(--size-5);
        }

        .search-input {
            width: 100%;
            padding: var(--size-3);
            font-size: var(--fs-400);
            border: 1px solid var(--border-light-gray);
            background: var(--ltclr);
            color: var(--blkclr);
            transition: border-color var(--transition-fast) ease;
        }

        .search-input:hover,
        .search-input:focus {
            outline: none;
            border-color: var(--blkclr);
        }

        .filter-btn {
            padding: var(--size-3);
            text-align: left;
            background: transparent;
            color: var(--blkclr);
            border: 1px solid var(--border-light-gray);
            transition: border-color var(--transition-fast) ease;
        }

        .filter-btn:hover {
            border-color: var(--blkclr);
        }

        .filter-btn:focus-visible {
            outline: 2px solid orange;
            outline-offset: 2px;
        }

        .filter-btn.active {
            background: var(--blkclr);
            color: var(--ltclr);
            border-color: var(--blkclr);
        }

        .blog-posts {
            columns: 1;
            column-gap: var(--size-5);
        }

        .blog-card {
            background: var(--ltclr);
            border: 1px solid var(--border-light-gray);
            color: var(--blkclr);
            transition: box-shadow var(--transition-fast) ease;
            border-radius: var(--size-250);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: var(--size-5);
            break-inside: avoid;
            margin-bottom: var(--size-5);
        }

        .blog-card:hover {
            box-shadow: 0 4px 24px var(--accent);
        }

        .blog-card img {
            --_img-width: 90px;

            width: var(--_img-width);
            height: var(--_img-width);
            border-radius: 100%;
            object-fit: cover;
            object-position: center;
            box-shadow: var(--shadow);
            flex-shrink: 0;
        }

        .reviewer-header {
            display: flex;
            align-items: center;
            gap: var(--size-3);
            margin-bottom: var(--size-750);
        }

        .meta-details {
            display: flex;
            flex-direction: column;
            gap: var(--size-1);
            min-width: 0;
        }

        .reviewer-name {
            font-size: var(--fs-450);
            font-weight: var(--fw-bold);
            margin: 0;
            text-transform: uppercase;
        }

        .quote-wrapper {
            position: relative;
            padding: 0 var(--size-7);
        }

        .quote-wrapper .text-content {
            margin: 0;
            line-height: var(--line-height-relaxed);
            font-size: var(--fs-350);
        }

        .quote {
            font-family: Georgia, serif;
            font-size: var(--fs-clamp-display);
            font-weight: var(--fw-normal);
            color: var(--faded);
            opacity: 0.3;
            position: absolute;
            line-height: 1;
        }

        .opening-quote {
            top: -0.25em;
            left: 0;
        }

        .closing-quote {
            bottom: -0.25em;
            right: 0;
        }


        @media (min-width: 40.0625em) {
            .blog-container {
                padding: 0 var(--size-5);
            }
            .blog-posts {
                columns: 2;
            }
        }

        @media (min-width: 48em) {
            .blog-container {
                width: 80%;
            }

            .main-content {
                grid-template-columns: 280px 1fr;
            }

            .filter-section {
                --_shadow: 0 8px 24px var(--shadow-clr-subtle);
                position: sticky;
                top: var(--size-12);
                margin-top: var(--size-10);
                padding: var(--size-7);
                border: 1px solid var(--border-light-gray);
                box-shadow: var(--_shadow);
            }

            .filter-toggle-btn {
                display: none;
            }

            .filter-header {
                border-bottom: none;
                padding-bottom: 0;
                margin-bottom: var(--size-3);
            }

            .filter-content {
                max-height: none;
                overflow: visible;
            }

            .filter-tabs {
                display: flex;
                flex-direction: column;
                gap: var(--size-2);
                margin: var(--size-5) 0;
            }
        }

        @media (min-width: 64em) {
            .blog-container {
                padding-inline: 0;
            }
            .blog-posts {
                columns: 3;
            }
        }

</style>