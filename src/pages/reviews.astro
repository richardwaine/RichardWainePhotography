---
import MainLayout from '../layouts/MainLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import { Image } from 'astro:assets';
import { ALL_TESTIMONIALS } from '../data/testimonials';
import { buildItemListSchema } from '../utils/schema';


// This grabs EVERY image in that folder in one go
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/testimonials/*.{jpeg,jpg,png,gif}');

const title = 'Richard Waine Photography Reviews';
const h1 = "Reviews"
---

<MainLayout title="Richard Waine Photography | Reviews" description="">

<!-- ItemList Schema for Vendor Directory -->
<!-- <script type="application/ld+json" set:html={JSON.stringify(vendorDirectorySchema)} /> -->

<PageTitle title={h1} titleColor="var(--ltclr)" />

    


<div id="app">
        <div class="blog-container">
            <div class="main-content">
                <section class="filter-section">
                    <div class="filter-header">
                        <h2 class="filter-title">Browse Reviews</h2>
                        <!-- NEW: Filter toggle button for mobile -->
                        <button id="filter-toggle" class="filter-toggle-btn">
                            Filter <span class="arrow">&#9660;</span>
                        </button>
                    </div>
                    <!-- NEW: Wrapper for filter content -->
                    <div class="filter-content" id="filter-content">
                        <div class="filter-tabs" id="category-filters">
                            <button class="filter-btn active" data-category="all">All</button>
                            <button class="filter-btn" data-category="executives">Corporate Executives</button>
                            <button class="filter-btn" data-category="corporate-professionals">Corporate Professionals</button>
                            <button class="filter-btn" data-category="entrepreneurs">Entrepreneurs</button>
                            <button class="filter-btn" data-category="company-employees">Company Employees</button>
                            <button class="filter-btn" data-category="creatives">Creative Professionals</button>
                            <button class="filter-btn" data-category="small-business-owners">Small Business Owners</button>
                            <button class="filter-btn" data-category="legal-professionals">Legal Professionals</button>
                            <button class="filter-btn" data-category="financial-professionals">Financial Professionals</button>
                            <!-- <button class="filter-btn" data-category="dj">DJ's</button> -->
                            <!-- Original HTML had commented out 'venue' button -->
                            <!-- <button class="filter-btn" data-category="venue">Venues</button> -->
                            <!-- <button class="filter-btn" data-category="event-planner">Event Planners</button> -->
                            <!-- <button class="filter-btn" data-category="caterer">Caterers</button> -->
                        </div>

                        <div class="search-container">
                            <input type="text" id="search-input" placeholder="Search Reviews..." class="search-input">
                        </div>
                    </div>
                </section>

                <main class="blog-grid">
                    <div class="category-heading">
                        <h2 id="current-category">All Reviews</h2>
                        <p id="post-count" class="post-count">Showing all Reviews</p>
                    </div>
                    <div class="blog-posts" id="blog-posts">
                        <!-- Vendor Cards (your existing content) - UNCHANGED from original -->
                        
                        
                           {ALL_TESTIMONIALS.map((testimonial) => {
    const fullPath = `/src/assets/images/testimonials/${testimonial.imagePath}`;

    return (
        <article class="blog-card" data-category={testimonial.category}>

            {/* <p class="stars">&#9733&nbsp&#9733&nbsp&#9733&nbsp&#9733&nbsp&#9733</p> */}

            {images[fullPath] ? (
                <Image src={images[fullPath]()} alt={testimonial.imageAlt} width={150} height={150} loading="eager" decoding="async" />
            ) : (
                <div class="image-placeholder">Image not found</div>
            )}
            <div class="blog-card-content">
                <div class="vendor-card-header">
                    <h3 class="blog-card-title vendor-card-title">{testimonial.name}</h3>

                    {/* <h4 class="vendor-card-category">{testimonial.company}</h4>  */}
                    
                </div>
                <div class="blog-card-excerpt">
                    <p><span class="quote opening-quote">&ldquo;</span>
                        {testimonial.review}
                        <span class="quote closing-quote">&rdquo;</span>
                    </p>
                </div>
            </div>
        </article>
    );
})}
                        
                    </div>
                
                </main>
            </div>
        </div>
    </div>


<script is:inline>
function initializeResourceFilters() {const b=document.querySelectorAll(".blog-card"),f=document.getElementById("category-filters"),d=document.getElementById("current-category"),c=document.getElementById("post-count"),s=document.getElementById("search-input");if(!f||!d||!c||!s)return;let a="all";const t={"all":"All Reviews","executives":"Corporate Executives","corporate-professionals":"Corporate Professionals","entrepreneurs":"Entrepreneurs","company-employees":"Company Employees","creatives":"Creative Professionals","small-business-owners":"Small Business Owners","legal-professionals":"Legal Professionals","financial-professionals":"Financial Professionals"};const filter=()=>{const term=s.value.toLowerCase();let v=0;b.forEach(card=>{const cats=card.dataset.category.toLowerCase().split(" "),matchCat=a==="all"||cats.includes(a),title=card.querySelector(".blog-card-title, .vendor-card-title")?.textContent.toLowerCase()||"",category=card.querySelector(".vendor-card-category")?.textContent.toLowerCase()||"",excerpt=card.querySelector(".blog-card-excerpt")?.textContent.toLowerCase()||"",matchSearch=!term||title.includes(term)||excerpt.includes(term)||category.includes(term);if(matchCat&&matchSearch){card.style.display="";v++}else{card.style.display="none"}});d.textContent=t[a]||`${a.replace(/-/g,' ')} Reviews`;c.textContent=`Showing ${v} Reviews`};f.onclick=e=>{if(e.target.classList.contains("filter-btn")){document.querySelectorAll(".filter-btn").forEach(btn=>btn.classList.remove("active"));e.target.classList.add("active");a=e.target.dataset.category;filter()}};s.oninput=filter;const toggle=document.getElementById("filter-toggle"),content=document.getElementById("filter-content");if(toggle&&content)toggle.onclick=()=>{content.classList.toggle("open");toggle.classList.toggle("active")};filter()}

// Initialize on page load and ViewTransitions
document.addEventListener("DOMContentLoaded", initializeResourceFilters);
document.addEventListener("astro:page-load", initializeResourceFilters);
document.addEventListener("astro:after-swap", initializeResourceFilters);
</script>


</MainLayout>

<style>

:root {
  --pagetitle-h1-margin: 0;
}

 /* Base styles (mobile-first defaults) */


        /* Reset and base styles - UNCHANGED from your original */
      
        body {
            
            background-color: var(--ltclr);
            background:var(--drkbg);

            color: var(--blkclr);
            color:var(--ltclr);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            
            font-weight: 600;
            margin-block: var(--size-3);
            text-wrap: balance;
        }

        #current-category {
            text-transform: capitalize;
        }

        h2 {
           
            font-size:var(--fs-500)
        }

        h3 {
            font-size:  var(--fs-400);
            font-weight:var(--fw-bold);
            text-transform:uppercase;
        }

        p {
            margin-bottom: var(--size-3);
            text-wrap: pretty;
            text-wrap:balance;
        }

        a {
            color: var(--accent);
            text-decoration: none;
        }

        button {
            cursor: pointer;
            font-family: inherit;
            outline: none;
        }

        /* Blog Container - UNCHANGED from your original */
        .blog-container {
            width:calc(100% - var(--size-7));
            margin-inline:auto;
        }

        .category-heading{
          margin-bottom: var(--size-3);
}

        /* Main Content - UNCHANGED from your original */
        .main-content {
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--size-7); 
            padding:var(--size-7) 0 0 0;
            justify-content: center;
            margin-bottom:var(--size-9);
        }

        /* Filter Section - MOBILE-FIRST defaults for collapsible behavior */
        .filter-section {
            position: relative; 
            top: auto; 
            height: fit-content; 
            padding: var(--size-3); 
            background: var(--ltclr);
            border: none;
            box-shadow: none; 
            border-radius: var(--size-2);
            margin-bottom: var(--size-4); 

         
        }

        /* Filter Header (contains title and toggle button) */
        .filter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: var(--size-3);
            margin-bottom: var(--size-3);
            border-bottom: 1px solid #e5e5e5; 
        }

        /* NEW: Filter Toggle Button - visible by default (mobile) */
        .filter-toggle-btn {
            display: flex; 
            background: var(--blkclr);
            color: var(--ltclr);
            border: none;
            padding: 10px 12px; 
            font-size: var(--fs-350);
            cursor: pointer;
            align-items: center;
            gap: var(--size-2);
            transition: background-color 0.2s ease, transform 0.3s ease;
        }

        .filter-toggle-btn:hover {
            background-color: #333;
        }

        .filter-toggle-btn .arrow {
            transition: transform 0.3s ease;
        }

        .filter-toggle-btn.active .arrow {
            transform: rotate(180deg);
        }

        /* NEW: Filter Content Wrapper - hidden by default (mobile) */
        .filter-content {
            max-height: 0; 
            overflow: hidden; 
            padding-top: 0;
            padding-bottom: 0; 
            transition: max-height 0.3s ease-out, padding 0.3s ease-out; 
        }

        .filter-content.open {
            max-height: 1000px; 
        }

        /* Filter Tabs - MOBILE-FIRST grid for buttons */
        .filter-tabs {
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: var(--size-2); 
            margin: 0 0 var(--size-5) 0; 
            font-size:var(--fs-400);
        }

        /* Search Container - UNCHANGED from your original */
        .search-container {
            margin-top:  var(--size-5);
        }

        /* Search Input - UNCHANGED from your original */
        .search-input {
            width: 100%;
            padding: var(--size-3);
            font-size: var(--fs-400);
            border: 1px solid #e5e5e5;
            background:var(--ltclr);
            color: var(--blkclr);
            transition: border-color 0.2s ease;
        }

        .search-input:hover {
            border-color: var(--blkclr);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--blkclr);
        }

        /* Filter Button - UNCHANGED from your original */
        .filter-btn {
            padding:  var(--size-3);
            text-align: left;
            background: transparent;
            color: var(--blkclr);
            border: 1px solid #e5e5e5;
            transition: border-color 0.2s ease; 
        }

        .filter-btn:hover {
            border-color: var(--blkclr);
            
        }

        .filter-btn:focus-visible {
            outline:2px solid orange;
            outline-offset:2px;
        }

        .filter-btn.active {
            background: var(--blkclr);
            color: var(--ltclr);
            border-color: var(--blkclr);
        }

        /* Blog Posts - UNCHANGED from your original */
        .blog-posts {
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--size-5);
        }

        /* Blog Card - UNCHANGED from your original */
        .blog-card {
            background: var(--ltclr);
            /* background:var(--drkbg); */

            border: 1px solid #e5e5e5;

    

            color: var(--blkclr);
            /* color:var(--ltclr); */

            transition: box-shadow 0.2s ease;
            border-radius: var(--size-250);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .blog-card:hover {
             /* --_shadow: 0 8px 24px var(--shadow-clr-subtle); */
              --_shadow: 0 4px 24px var(--accent);
            box-shadow:var(--_shadow);
        }

        .stars{
            margin:.5em auto;
            color:var(--stars);
        }

        .blog-card img {
            
            --_img-width:125px;
        
            
            
            width:var(--_img-width);
            height:var(--_img-width);
            border-radius:100%;
            margin-block:1em;
            margin-inline:auto;
            object-fit: cover;
            object-position: center;
            box-shadow:var(--shadow);

            
        }

    

        .blog-card-content {
            padding:var(--size-3);
            flex-grow: 1;
            display: flex;
            flex-direction: column;

            /* justify-content: space-between; */
        }

        .vendor-card-header {
            margin: 0;
            padding: 0;
            text-align:center;
        }

        .vendor-card-category {
            padding-inline: var(--size-1);
            background: transparent;
            color: var(--blkclr);
            font-size: var(--fs-350);
            margin-bottom: var(--size-3);

            
        }

        .vendor-address,
        .vendor-phone {
            margin: var(--size-1) 0;
            color: var(--blkclr);
            font-size: var(--fs-350);
        }

        .vendor-website,
        .vendor-email {
            display: inline-block;
            margin-top: var(--size-2);
            color: #0066cc;
            text-decoration: none;
            font-weight: var(--fw-semi-bold);
        }

        .vendor-website:hover {
            text-decoration: none;
        }

        .vendor-website:focus-visible,                                                            
        .vendor-email:focus-visible {                                                             
            outline: 2px solid orange;                                                            
            outline-offset: 2px;                                                                  
        }  

        .blog-card-excerpt {
            font-size: var(--fs-350);
            margin-top: var(--size-3);
            padding: var(--size-1);
            display: -webkit-box;
            -webkit-line-clamp: ; /* 8 or 9 */
            -webkit-box-orient: vertical;
            overflow: hidden;
            
        }

        .blog-card h3 {
            margin-block: var(--size-2);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            word-wrap: break-word;
            padding-inline: 0.15em;

            
        }

        .blog-card h4 {
            font-weight: var(--fw-normal);
            margin: 0;
            padding-block: 0;
        }


    /* ==========================================
   MOBILE / TABLET - min-width: 40.0625em (641px)
    ========================================== */

        @media (min-width: 40.0625em) { 
            .blog-container {
                padding: 0 var(--size-5);
            }
            .blog-posts {
                grid-template-columns: repeat(1, 1fr);
            }
        }

    /* ==========================================
    TABLET - min-width: 48em (768px)
    ========================================== */

        @media (min-width: 48em) {
            .blog-container {
            width:80%;
            }

            /* Main content grid layout - UNCHANGED from original, allowing gap to inherit */
            .main-content {
                grid-template-columns: 280px 1fr;
            }
            /* Blog card image height - UNCHANGED from original */
            .blog-card img {
                --_img-width:125px;

                height: var(--_img-width);
                width: var(--_img-width);
            }
            /* Filter section reverts to desktop sticky behavior and appearance */
            .filter-section {

            --_shadow: 0 8px 24px var(--shadow-clr-subtle);

                position: sticky;
                top: 325px;
                padding: var(--size-7);
                border: 1px solid #e5e5e5;
                box-shadow: var(--_shadow);
            }
            /* Hide toggle button on desktop */
            .filter-toggle-btn {
                display: none;
            }
            /* Ensure filter header looks original on desktop */
            .filter-header {
                border-bottom: none; 
                padding-bottom: 0;
                margin-bottom: var(--size-3); 
            }
            /* Ensure filter content is visible on desktop */
            .filter-content {
                max-height: none;
                overflow: visible;
            }
            /* Filter tabs layout reverts to desktop column for menu */
            .filter-tabs {
                display: flex;
                flex-direction: column; 
                gap: var(--size-2); 
                margin: var(--size-5) 0; 
            }
        }

    /* ==========================================
    LARGE DESKTOP - min-width: 64em (1024px)
    ========================================== */
        @media (min-width: 64em) {
            .blog-container {
                padding-inline: 0;
            }
            .blog-posts {
                grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            }
        }

</style>