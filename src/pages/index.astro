---
// @ts-nocheck
import { getImage } from "astro:assets";
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ZoomPopOut from '../components/ZoomPopOut.astro';
import Problem from '../components/Problem.astro';
import Features from '../components/Features.astro';
import OfficeHeadshots from '../components/OfficeHeadshots.astro';
import TearSheet from '../components/TearSheet.astro';
import Testimonials from '../components/Testimonials.astro';
import Process from '../components/Process.astro';
import BriefBio from '../components/BriefBio.astro';
import HeadshotsNear from '../components/HeadshotsNear.astro';
import Professions from '../components/Professions.astro';
import DidYouKnow from '../components/DidYouKnow.astro';
import FAQs from '../components/FAQs.astro';
import NeuralPortrait from '../components/NeuralPortrait.astro';
import FloatingStats from '../components/FloatingStats.astro';
import videoPoster from '../assets/RW_FINAL_V1_FOR REVIEW.00_00_48_06.Still004 (16 x 9) - compressed.jpg';


const promoVideo = 'https://media.richardwainephotography.com/RW_V2_For%20Review-2.mp4';

const captions = 'https://media.richardwainephotography.com/captions.vtt';

import WorldMap from '../components/WorldMap.astro';
import { buildVideoObjectSchema, buildReviewSchema, buildServiceSchema } from '../utils/schema';

const title = 'Richard Waine Photography';
const h1 = 'Professional Headshots Lancaster';

// Hero section content
const heroContent = {
  title: ["WORLD CLASS", "HEADSHOT", "EXPERIENCE"],
  h1: h1,
  primaryButtonText: "GET PRICING",
  secondaryButtonText: "SCHEDULE CONSULT",
  heroImages: [
    '/src/assets/images/hero-images/Ken Giglio (16 x 9) - compressed.jpg',
    '/src/assets/images/hero-images/Cindy Nguyen (16 x 9) - compressed.jpg'
  ],
  mainHeading: h1
};

// Video schema
const promoVideoSchema = buildVideoObjectSchema(
  {
    name: "Professional Headshot Photography Experience - Richard Waine",
    description: "See what it's like to work with professional headshot photographer Richard Waine. Experience the process, direction, and results that make great headshots.",
    thumbnailUrl: "https://richardwainephotography.com" + (await getImage({ src: videoPoster, width: 800 })).src,
    uploadDate: "2024-01-15T00:00:00-05:00",
    embedUrl: promoVideo
  },
  "Richard Waine Photography"
);

// Review schemas
const wendyBookerReview = buildReviewSchema(
  {
    author: "Wendy Booker",
    company: "Armstrong Flooring, Inc.",
    rating: "5",
    reviewBody: "Rich captured exactly the look and feel I wanted in my headshots. He demands the best from himself and his subjects, and it shows. Thank you for taking my re-branding efforts to the next level!"
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

const scottKantnerReview = buildReviewSchema(
  {
    author: "Scott Kantner",
    company: "Larson Design Group",
    rating: "5",
    reviewBody: "Richard is the person you want to do your headshots. Stop searching, don't hesitate, just stop reading this and make the appointment. You won't find anyone better, nor a more enjoyable experience."
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

const ellenTaylorReview = buildReviewSchema(
  {
    author: "Ellen Taylor",
    company: "The Center For Health Design",
    rating: "5",
    reviewBody: "Relaxed. Results. Repeat. Richard's approach is perfect to get the best 'you' for your headshot. Your trepidations will gradually disappear as he walks you through the session. I will be back!"
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

// Service schema for Lancaster
const lancasterHeadshotsServiceSchema = buildServiceSchema(
  "Lancaster Headshots",
  "Professional Headshot Photography in Lancaster",
  "Professional headshots in Lancaster, Pennsylvania. Richard Waine Photography provides world-class headshot photography services from our Lancaster studio, offering corporate headshots, business headshots, executive portraits, and acting headshots.",
  "Richard Waine Photography",
  "Lancaster",
  "PA",
  "+1-717-925-0061",
  ["Pennsylvania", "Lancaster", "Central Pennsylvania"]
);



---

<MainLayout title = "Professional Headshot Photographer | Lancaster, PA" description="Lancaster Pennsylvania's Best Photographer for professional, office, business, corporate, and acting headshots. Serving Lititz, Ephrata, and the Lancaster area">

	<!-- Video Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(promoVideoSchema)} />

	<!-- Review Schemas -->
	<script type="application/ld+json" set:html={JSON.stringify(wendyBookerReview)} />
	<script type="application/ld+json" set:html={JSON.stringify(scottKantnerReview)} />
	<script type="application/ld+json" set:html={JSON.stringify(ellenTaylorReview)} />

	<!-- Service Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(lancasterHeadshotsServiceSchema)} />



	<section id="hero">
	<Hero
		title={heroContent.title}
		h1={heroContent.h1}
		primaryButtonText={heroContent.primaryButtonText}
		secondaryButtonText={heroContent.secondaryButtonText}
		heroImages={heroContent.heroImages}
		mainHeading={heroContent.mainHeading}
	/>

    </section>

	<section id="problem">

		<Problem />

	</section>

	<section id="features">

		<Features
			businessSlideText={[
				"Your business headshots show clients what kind of professional they're considering. People look at your photos and form quick opinions about whether they trust you and want to do business with you. Professional corporate headshots present you as credible and established. Strong images give you an advantage when prospects are evaluating who to hire. The visual standard you set affects how clients value your work.",

				"Trust drives whether clients choose to work with you. Your business headshots need to match the level of professionalism and quality you bring to your actual work. When what people see in your corporate headshots matches what you deliver in reality, they feel confident about hiring you. That alignment between your visual presentation and your capabilities strengthens the client relationships you build.",

				"Strong business headshots prepare you for opportunities that come up throughout your career. Whether you need to project authority in your industry or approachability that makes clients comfortable reaching out, having professional corporate headshots ready means you're prepared for whatever direction your work takes. When opportunities develop, your business profile photo is already in place and working to support the professional reputation you've built over time. "

			]}

			actingSlideText={[
				"Casting directors review hundreds of actor headshots for every role they're trying to fill. Your photos compete against every other performer submitting for the same part. Professional acting headshots give you the visual presence that makes casting directors actually look at you instead of passing you by. When your images grab their attention, you're in the conversation for roles you want.",

				"Your acting headshots get evaluated for type, energy, authenticity, and whether you fit the character vision. The people making casting decisions use your photos to assess if you match what the production needs. Strong actor headshots communicate that fit clearly and show exactly who you are as a performer. The right photos help them see you in the role they're trying to fill.",

				"I have worked with Lancaster actors and performers throughout my career creating headshots that get them auditions. The performer headshots I deliver show you authentically while meeting the technical standards casting directors expect. My goal is producing acting headshots that capture what makes you unique as a performer and align with the specific requirements of your craft. When your photos do that job effectively, they open doors to the roles that actually fit you. "

			]}

			linkedinSlideText={[
				"Professionals use LinkedIn to build networks, discover opportunities, and connect with potential clients. Your LinkedIn profile photo appears alongside everything you post, every connection request you send, and every time someone searches for professionals in your field. A weak LinkedIn headshot undermines your credibility regardless of how strong your experience or credentials are. Professional LinkedIn profile photos position you as someone worth connecting with and doing business with.",

				"Your LinkedIn headshot tells people how seriously you take your professional presence. When you show up with a polished LinkedIn profile photo, prospects and connections notice the attention to detail. That same care you bring to your visual presentation signals the excellence you bring to your actual work. People make assumptions about your business standards based on how you present yourself on LinkedIn.",

				"Building a business through LinkedIn requires more than just an active profile and regular content. You need to look like the established professional and authority in your field that you actually are. Your LinkedIn headshots play a direct role in whether prospects see you as credible and capable of solving their problems. When your LinkedIn profile photo matches the quality of your expertise, you're positioned to attract the clients and opportunities you're working to create."
			]}

			officeSlideText={[
				"Your team members are the most visible extension of your brand. Every client interaction, every LinkedIn connection, every website visit puts your employees in front of prospects. When team headshots look mismatched with different lighting, backgrounds, and quality levels, your company appears fragmented instead of unified. Professional office headshots that match across your entire organization communicate that your business operates under consistent standards.",

				"Employees who receive headshots they actually like represent your company with more confidence. When you invest in professional office headshots for your team, that investment demonstrates their value to the organization. Team members who feel valued carry themselves more confidently in client interactions and advocate more effectively for your company culture. Professional employee headshots contribute to how your staff sees themselves as part of your organization. ",

				"Getting professional employee headshots establishes your business as an organization that takes its image seriously. Clients evaluate your company based on how your team presents themselves online and in materials. Group headshots that demonstrate visual consistency tell prospects your business pays attention to details that matter."

			]}

		/>

	</section>



	<section id="promo-video">
    <div class="video-container">
        <div class="video-wrapper">
            <button class="close-video-btn" aria-label="Close video">×</button>
                <video class="promo-video" 
                controls
                crossorigin="anonymous"
                controlslist="nodownload noplaybackrate nopictureinpicture" 
                loop width="1000" 
                height="563" 
                poster={(await getImage({ src: videoPoster, width: 800 })).src}
                src={promoVideo}
                >

                    <source src={promoVideo} type="video/mp4">
                    <track kind="captions" src={captions} srclang="en" label="English" default>
                </video>
        </div>
    </div>
  </section>



	<section id="neural-portrait">
		<NeuralPortrait />

	</section>

	<section id="tear-sheet">
		<TearSheet />

	</section>

	<section id="office-headshots">
		<OfficeHeadshots />
		
	</section>


	<section id="what-to-expect">

    <WorldMap />

	</section>


	<section id="testimonials">
		<Testimonials limit={3} filterByNames={["Wendy Booker", "Scott Kantner", "Ellen Taylor"]}/>
	</section>

	<section id="process">
		<Process />
	</section>

	<section id="brief-bio">
		<BriefBio
  bioSectionHeading="Lancaster Headshot Photographer"
  bioSections={[
    {
      clipHeading: "LANCASTER HEADSHOT PHOTOGRAPHY",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "By now you probably realize that professional headshot photography is about more than just nice pictures, and I am much more than a portrait photographer.", showOnMobile: true },
        { text: "Over 17 years, I have specialized exclusively in headshot photography in Lititz, Manheim, Ephrata, Elizabethtown, Mount Joy, and throughout Lancaster PA, photographing <a href='/business-headshots/'>business professionals</a>, actors, executives, and providing corporate headshots for companies and teams.", showOnMobile: true },
        { text: "I am the best headshot photographer in Lancaster PA and Central Pennsylvania, specializing in corporate headshots, executive portraits, acting headshots, and professional photography in Lancaster City, Lititz, Ephrata, E-town, and Mount Joy.", showOnMobile: true }
      ]
    },
    {
      clipHeading: "PROFESSIONAL HEADSHOTS NEAR LANCASTER",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "As your professional headshot photographer and trusted advisor, I provide a premium experience, while removing any anxiety or feelings of discomfort over having your photo taken.", showOnMobile: true },
        { text: "Having your headshot taken should be an enjoyable, and dynamic experience.", showOnMobile: true }
      ]
    },
    {
      clipHeading: "PROFESSIONAL HEADSHOT PHOTOGRAPHER",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "I have built my career helping individuals, like yourself, make more money, reduce expenses, and expand market share by capturing the best headshots around.", showOnMobile: true },
        { text: "Your professional headshot needs to showcase you at your best. A modern headshot demonstrates that you have a contemporary mindset, and visionary perspective.", showOnMobile: true },
        { text: "I am committed to providing you with an easy, first-class experience, while creating high quality headshots that you are proud to use everywhere!", showOnMobile: true },
        { text: "I love what I do, and I have a blast doing it! Come and see what all the fuss is about!", showOnMobile: true }
      ]
    }
  ]}
/>
		<FloatingStats />
	</section>


	<section id="hs-near">
    <HeadshotsNear 
      mainHeading="Headshots Near Lancaster"
      paragraphs={[
         "<p>Richard Waine Photography is conveniently located in the heart of the downtown investment district in Lancaster, Pennsylvania.</p>",
    "<p>The studio sits next to Lancaster Central Market, directly across from Fulton Bank and the Lancaster County Convention Center. It is a stone's throw from the major highways as well as the Lancaster Train Station.</p>",
    "<p>Richard Waine Photography serves Lititz, Manheim, Ephrata, Elizabethtown, Mount Joy, and the greater Lancaster PA area with studio headshots at our downtown Lancaster location.</p>",
    `<p style="display:inline">When you think about "<h2
  class="hs-near-inline-h2">headshots near me</h2>", or "<h2
  class="hs-near-inline-h2">professional headshots near me</h2>" think Richard
  Waine Photography, Lancaster's best headshot photographer.</p>`,
    `<p style="display:inline">For large groups,<h2 class="hs-near-inline-h2">
  corporate headshots</h2>,<h2 class="hs-near-inline-h2"> company headshots</h2>,
  and<h2 class="hs-near-inline-h2"> on location headshots</h2>, I offer my services
   in the comfort of your office, or at your event.</p>`
  ]}
      locationColumns={[
        ["Lancaster City Headshots", "Lititz Headshots", "Manheim Headshots"],
        ["Ephrata Headshots", "Elizabethtown Headshots", "Mount Joy Headshots"],
        ["Leola Headshots", "Millersville Headshots", "Willow Street Headshots"]
      ]}
    />
  </section>

	<section id="professions">
		<Professions />

	</section>

	<section id="did-you-know">
			<DidYouKnow />

		</section>

	<section id="faqs">
			<FAQs />

		</section>

</MainLayout>


<style>
  
#hero{

padding:0;
min-height:calc(100vh + 120px);
display:grid;
place-items:center;

}
	
/*video section */

#promo-video {
    padding-block: var(--size-8);
}

.video-container {
    height: auto;
   
}

.video-wrapper {
    width: min(800px, 100%);
    position: relative;
    padding-inline: var(--size-4);
    margin-inline: auto; 
}

.video-wrapper .promo-video {
    width: 100%;
    height: auto;
    display: block;
	  
}

/* Close Button Styling */
.close-video-btn {
    display: none;
    position: absolute;
    top: -15px;
    right: -15px;
    width: 30px;
    height: 30px;
    background: #000;
    color: #fff;
    border: 2px solid #fff;
    border-radius: 50%;
    cursor: pointer;
    z-index: 1001;
    font-size: 20px;
    line-height: 1;
    align-items: center;
    justify-content: center;
}

/* Fixed State */
.video-wrapper.fixed {
    width: 400px;
    position: fixed;
    bottom: 25px;
    left: 25px;
    z-index: 1000;
}

.video-wrapper.fixed .close-video-btn {
    display: flex;
}


/* 100vh sections */
#features, #neural-portrait, #office-headshots, #testimonials, #brief-bio, #problem
{
	min-height:100vh;
	display:grid;
	place-items:center;
}

/* Natural height sections */
#promo-video, #tear-sheet, #process, #hs-near, #professions, #did-you-know, #faqs {
	height: auto;
	display:grid;
	place-items:center;

}

/* Dark background sections */
#features, #neural-portrait, #office-headshots, #testimonials, #brief-bio, #professions{
	background:var(--drkbg);
}

#brief-bio{
  display:flex;
  flex-direction:column;
  gap:var(--size-8);
  justify-content: center;
  
}

</style>


