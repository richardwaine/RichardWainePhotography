---
// @ts-nocheck
import { getImage } from "astro:assets";
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ZoomPopOut from '../components/ZoomPopOut.astro';
import Problem from '../components/Problem.astro';
import Features from '../components/Features.astro';
import OfficeHeadshots from '../components/OfficeHeadshots.astro';
import TearSheet from '../components/TearSheet.astro';
import Testimonials from '../components/Testimonials.astro';
import Process from '../components/Process.astro';
import BriefBio from '../components/BriefBio.astro';
import HeadshotsNear from '../components/HeadshotsNear.astro';
import Professions from '../components/Professions.astro';
import DidYouKnow from '../components/DidYouKnow.astro';
import FAQs from '../components/FAQs.astro';
import NeuralPortrait from '../components/NeuralPortrait.astro';
import FloatingStats from '../components/FloatingStats.astro';
import videoPoster from '../assets/RW_FINAL_V1_FOR REVIEW.00_00_48_06.Still004 (16 x 9) - compressed.jpg';


const promoVideo = 'https://media.richardwainephotography.com/RW_V2_For%20Review-2.mp4';

const captions = 'https://media.richardwainephotography.com/captions.vtt';

import WorldMap from '../components/WorldMap.astro';
import { buildVideoObjectSchema, buildReviewSchema, buildServiceSchema, buildBreadcrumbSchema } from '../utils/schema';

const title = 'York Headshots | Richard Waine Photography';
const h1 = 'Professional Headshots York';

// Hero section content
const heroContent = {
  title: ["WORLD CLASS", "HEADSHOT", "EXPERIENCE"],
  h1: h1,
  primaryButtonText: "GET PRICING",
  secondaryButtonText: "SCHEDULE CONSULT",
  heroImages: [
    '/src/assets/images/hero-images/Ken Giglio (16 x 9) - compressed.jpg',
    '/src/assets/images/hero-images/Cindy Nguyen (16 x 9) - compressed.jpg'
  ],
  mainHeading: h1
};

// Video schema
const promoVideoSchema = buildVideoObjectSchema(
  {
    name: "Professional Headshot Photography Experience - Richard Waine",
    description: "See what it's like to work with professional headshot photographer Richard Waine. Experience the process, direction, and results that make great headshots.",
    thumbnailUrl: "https://richardwainephotography.com" + (await getImage({ src: videoPoster, width: 800 })).src,
    uploadDate: "2024-01-15T00:00:00-05:00",
    embedUrl: promoVideo
  },
  "Richard Waine Photography"
);

// Review schemas
const wendyBookerReview = buildReviewSchema(
  {
    author: "Wendy Booker",
    company: "Armstrong Flooring, Inc.",
    rating: "5",
    reviewBody: "Rich captured exactly the look and feel I wanted in my headshots. He demands the best from himself and his subjects, and it shows. Thank you for taking my re-branding efforts to the next level!"
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

const scottKantnerReview = buildReviewSchema(
  {
    author: "Scott Kantner",
    company: "Larson Design Group",
    rating: "5",
    reviewBody: "Richard is the person you want to do your headshots. Stop searching, don't hesitate, just stop reading this and make the appointment. You won't find anyone better, nor a more enjoyable experience."
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

const ellenTaylorReview = buildReviewSchema(
  {
    author: "Ellen Taylor",
    company: "The Center For Health Design",
    rating: "5",
    reviewBody: "Relaxed. Results. Repeat. Richard's approach is perfect to get the best 'you' for your headshot. Your trepidations will gradually disappear as he walks you through the session. I will be back!"
  },
  "Richard Waine Photography",
  "https://richardwainephotography.com"
);

// Service schema
const yorkHeadshotsServiceSchema = buildServiceSchema(
  "York Headshots",
  "Professional Headshot Photography in York",
  "Professional headshots in York, Pennsylvania. Richard Waine Photography provides world-class headshot photography services for York professionals, offering corporate headshots, business headshots, and executive portraits.",
  "Richard Waine Photography",
  "Lancaster",
  "PA",
  "+1-717-925-0061",
  ["Pennsylvania", "York"]
);

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: Astro.site.href },
  { name: "York Headshots", url: new URL('/york-headshots/', Astro.site).href }
]);

---

<MainLayout title = "Richard Waine | York Headshot Photographer" description="York, PA professional headshot photography. Corporate portraits, business headshots, LinkedIn photos for York County professionals. Studio and on-location.">

	<!-- Service Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(yorkHeadshotsServiceSchema)} />

	<!-- Video Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(promoVideoSchema)} />

	<!-- Review Schemas -->
	<script type="application/ld+json" set:html={JSON.stringify(wendyBookerReview)} />
	<script type="application/ld+json" set:html={JSON.stringify(scottKantnerReview)} />
	<script type="application/ld+json" set:html={JSON.stringify(ellenTaylorReview)} />

	<!-- Breadcrumb Schema -->
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

	<section id="hero">
	<Hero
		title={heroContent.title}
		h1={heroContent.h1}
		primaryButtonText={heroContent.primaryButtonText}
		secondaryButtonText={heroContent.secondaryButtonText}
		heroImages={heroContent.heroImages}
		mainHeading={heroContent.mainHeading}
	/>

    </section>

	<section id="problem">

		<Problem />

	</section>

	<section id="features">

		<Features
			businessSlideText={[
				"Business headshots don't need to feel like a chore or look stiff and uncomfortable. A professional headshot session can be straightforward and even enjoyable while still delivering images that build credibility with your clients. When you invest in quality business portraits, you're showing clients and prospects that you take your professional image seriously. That attention to detail translates directly into trust.",

				"Trust is everything in business relationships. When your team's headshots look consistent across your website, LinkedIn profiles, and marketing materials, you're reinforcing your brand messaging. Professional business headshots ensure everyone on your team presents the same level of quality and professionalism. That consistency tells clients your company pays attention to details that matter.",

				"Your professional goals might be about inspiring and motivating your team, or they might focus on diplomacy and approachability with clients. In either case, a high-quality corporate headshot positions you for success. Professional business headshots give you the credibility and polish that support whatever direction your career takes you. The right business portrait makes sure clients see you as the professional capable of delivering what they need."

			]}

			actingSlideText={[
				"Casting directors and agents review hundreds of headshots every day looking for performers who fit their vision. Professional acting headshots give you a real shot at grabbing their attention when they're deciding who gets called in. Your headshot needs to communicate who you are as a performer clearly enough that casting directors want to see more. ",

				"Your acting headshots determine whether casting directors see you as right for a role before you ever audition. They use your photo to assess your type, your range, and whether your look matches what the production needs. A strong headshot gets you in the room where you can show what you're capable of. ",

				"I have spent my career specializing in headshot photography, working with York actors and performers to create images that actually get them noticed. The work I deliver gives performers professional headshots they can confidently submit for any audition. My goal is producing acting headshots that capture your essence as a performer while aligning with what your specific craft demands and showcasing your personality."

			]}

			linkedinSlideText={[
				"Professionals use LinkedIn to discover business opportunities, connect with potential clients, and build their network. Your profile photo appears before your headline, before your experience, before anything else someone reads about you. When your LinkedIn headshot looks unprofessional or outdated, you've already lost the chance to make a strong first impression.",

				"Your LinkedIn profile photo tells a story about how you approach your professional life. An exceptional LinkedIn headshot signals that you value quality and understand the importance of presenting yourself well. The attention you give to your professional image reflects the same care you bring to your work and your client relationships.",

				"Success on LinkedIn goes beyond having an active presence and sharing content regularly. People need to see you as a credible expert in your field who can deliver what they're looking for. Your LinkedIn headshot plays a direct role in establishing that credibility and positioning you as the professional who understands and solves the challenges your clients face. "
			]}

			officeSlideText={[
				"Companies hire teams of talented people to run operations, serve clients, and drive growth. Those people represent your brand in every interaction they have with your market. When your team presents themselves with professional office headshots across your website and LinkedIn, they look like the credible, established business you've built. Inconsistent or amateur photos undermine that credibility before clients ever interact with your company.",

				"Your company invests heavily in building a brand identity that communicates your values and differentiates you from competitors. Marketing campaigns, brand messaging, and visual identity all cost substantial money because they directly impact revenue. Professional office headshots for your team become part of that brand infrastructure. When your employees look consistent and polished across all platforms, they reinforce the brand work you've already paid for. ",

				"Clients and prospects notice when a company pays attention to details. Employee headshots across your website, team pages, and marketing materials demonstrate that quality matters to your organization at every level. When potential clients see a unified, polished team presentation, they make assumptions about how your company operates, communicates, and delivers work. Those assumptions either work in your favor or they don't. "

			]}

		/>

	</section>

	<section id="promo-video">
    <div class="video-container">
        <div class="video-wrapper">
            <button class="close-video-btn" aria-label="Close video">×</button>
                <video class="promo-video" 
                controls
                crossorigin="anonymous" 
                controlslist="nodownload noplaybackrate nopictureinpicture" 
                loop width="1000" 
                height="563" 
                poster={(await getImage({ src: videoPoster, width: 800 })).src}
                src={promoVideo}
                >

                    <source src={promoVideo} type="video/mp4">
                    <track kind="captions" src={captions} srclang="en" label="English" default>
                </video>
        </div>
    </div>
  </section>


	<section id="neural-portrait">
		<NeuralPortrait />

	</section>

	<section id="tear-sheet">
		<TearSheet />

	</section>

	<section id="office-headshots">
		<OfficeHeadshots />
	</section>

	<section id="what-to-expect">

     <WorldMap />
	
	</section>



	<section id="testimonials">
		<Testimonials limit={3} filterByNames={["Wendy Booker", "Scott Kantner", "Ellen Taylor"]}/>
	</section>

	<section id="process">
		<Process />
	</section>

	<section id="brief-bio">
		<BriefBio
  bioSectionHeading="York Headshot Photographer"
  bioSections={[
    {
      clipHeading: "YORK HEADSHOT PHOTOGRAPHY",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "By now you probably realize that professional headshot photography is about more than just nice pictures.", showOnMobile: true },
        { text: "Over 17 years, I have specialized exclusively in headshot photography in York City, Red Lion, Dallastown, Hanover, Spring Grove, and throughout York, photographing <a href='/business-headshots/'>business professionals</a>, actors, executives, and providing corporate headshots for companies and teams.", showOnMobile: true }, 
        { text: "I am the best headshot photographer in York PA and the greater area, specializing in corporate headshots, executive portraits, acting headshots, and professional photography in York City, Red Lion, Dallastown, and Hanover.", showOnMobile: true }
      ]
    },
    {
      clipHeading: "PROFESSIONAL HEADSHOTS NEAR YORK",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "As your professional headshot photographer and trusted advisor, I provide a premium experience, while removing any anxiety or feelings of discomfort over having your photo taken.", showOnMobile: true },
        { text: "Having your headshot taken should be an enjoyable, and dynamic experience.", showOnMobile: true }
      ]
    },
    {
      clipHeading: "PROFESSIONAL HEADSHOT PHOTOGRAPHER",
      showHeadingOnMobile: false,
      clipParagraphs: [
        { text: "I have built my career helping individuals, like yourself, make more money, reduce expenses, and expand market share by capturing the best headshots around.", showOnMobile: true },
        { text: "Your professional headshot needs to showcase you at your best. A modern headshot demonstrates that you have a contemporary mindset, and visionary perspective.", showOnMobile: true },
        { text: "I am committed to providing you with an easy, first-class experience, while creating high quality headshots that you are proud to use everywhere!", showOnMobile: true },
        { text: "I love what I do, and I have a blast doing it! Come and see what all the fuss is about!", showOnMobile: true }
      ]
    }
  ]}
/>
		<FloatingStats />
	</section>

	<section id="hs-near">
    <HeadshotsNear 
      mainHeading="Headshots Near York"
      paragraphs={[
         "<p>Richard Waine Photography is a full-service headshot photography studio, conveniently located in the heart of the downtown investment district in Lancaster, Pennsylvania.</p>",
    "<p>The studio sits next to Lancaster Central Market, directly across from Fulton Bank and the Lancaster County Convention Center. It is a stone's throw from the major highways as well as the Lancaster Train Station.</p>",
    "<p>Richard Waine Photography serves Red Lion, Dallastown, Hanover, Spring Grove, Glen Rock, and the greater York area with on-location corporate headshots at your office or at our Lancaster studio.</p>",
    `<p style="display:inline">When you think about "<h2
  class="hs-near-inline-h2">headshots near me</h2>", or "<h2
  class="hs-near-inline-h2">professional headshots near me</h2>" think Richard
  Waine Photography, York's best headshot photographer.</p>`,
    `<p style="display:inline">For large groups,<h2 class="hs-near-inline-h2">
  corporate headshots</h2>,<h2 class="hs-near-inline-h2"> company headshots</h2>,
  and<h2 class="hs-near-inline-h2"> on location headshots</h2>, I offer my services
   in the comfort of your office, or at your event.</p>`
  ]}
      locationColumns={[
        ["York City Headshots", "Red Lion Headshots", "Dallastown Headshots"],
        ["Hanover Headshots", "Spring Grove Headshots", "Glen Rock Headshots"],
        ["Dover Headshots", "Shrewsbury Headshots", "New Oxford Headshots"]
      ]}
    />
  	</section>

	<section id="professions">
		<Professions />

	</section>

	<section id="did-you-know">
			<DidYouKnow />

		</section>

	<section id="faqs">
			<FAQs />

		</section>

</MainLayout>


<style>

#hero{
padding:0;
min-height:calc(100vh + 120px);
display:grid;
place-items:center;

}
	
/*video section */
#promo-video {
    padding-block: var(--size-8);
}

.video-container {
    height: auto;
}

.video-wrapper {
    width: min(800px, 100%);
    position: relative;
    padding-inline: var(--size-4);
    margin-inline: auto;
}

.video-wrapper .promo-video {
    width: 100%;
    height: auto;
    display: block;
	
}

/* Close Button Styling */
.close-video-btn {
    display: none;
    position: absolute;
    top: -15px;
    right: -15px;
    width: 30px;
    height: 30px;
    background: #000;
    color: #fff;
    border: 2px solid #fff;
    border-radius: 50%;
    cursor: pointer;
    z-index: 1001;
    font-size: 20px;
    line-height: 1;
    align-items: center;
    justify-content: center;
}

/* Fixed State */
.video-wrapper.fixed {
    width: 400px;
    position: fixed;
    bottom: 25px;
    left: 25px;
    z-index: 1000;
}

.video-wrapper.fixed .close-video-btn {
    display: flex;
}

/* 100vh sections */
#features, #neural-portrait, #office-headshots, #testimonials, #brief-bio, #problem
{
	min-height:100vh;
	display:grid;
	place-items:center;
}

/* Natural height sections */
#promo-video, #tear-sheet, #process, #hs-near, #professions, #did-you-know, #faqs {
	height: auto;
	display:grid;
	place-items:center;
}

/* Dark background sections */
#features, #neural-portrait, #office-headshots, #testimonials, #brief-bio, #professions{
	background:var(--drkbg);
}

#brief-bio{
  display:flex;
  flex-direction:column;
  gap:var(--size-8);
  justify-content: center;
  
}

</style>



